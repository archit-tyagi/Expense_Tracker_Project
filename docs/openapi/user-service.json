{"openapi":"3.1.0","info":{"title":"UserService API","description":"User profile management for ExpenseTracker.","version":"v1"},"servers":[{"url":"/","description":"Via Kong gateway"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"User Info","description":"User profile read and update. The X-User-Id header is injected by the Kong gateway after token validation."}],"paths":{"/user/v1/updateUser":{"post":{"tags":["User Info"],"summary":"Create or update the user's profile","operationId":"updateUser","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserInfoDTO"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string"}}}}}}},"/user/v1/getUser":{"get":{"tags":["User Info"],"summary":"Get the current user's profile","operationId":"getUser","parameters":[{"name":"X-User-Id","in":"header","description":"User id, injected by Kong from the validated token","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserInfoDTO"}}}}}}}},"components":{"schemas":{"UserInfoDTO":{"type":"object","properties":{"userId":{"type":"string"},"firstName":{"type":"string"},"lastName":{"type":"string"},"email":{"type":"string"},"phoneNumber":{"type":"integer","format":"int64"}}}},"securitySchemes":{"bearerAuth":{"type":"http","scheme":"bearer","bearerFormat":"JWT"}}}}