{"openapi":"3.1.0","info":{"title":"AuthService API","description":"Authentication, registration and JWT issuance for ExpenseTracker.","version":"v1"},"servers":[{"url":"/","description":"Via Kong gateway"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"Authentication","description":"Registration, login, logout and token validation"}],"paths":{"/auth/v1/signup":{"post":{"tags":["Authentication"],"summary":"Register a new user","description":"Public endpoint. Creates a user account.","operationId":"signUp","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserInfoDTO"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string"}}}}},"security":[]}},"/auth/v1/logout":{"post":{"tags":["Authentication"],"summary":"Log out","description":"Requires a valid bearer token. Revokes the user's refresh token.","operationId":"logout","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string"}}}}}}},"/auth/v1/login":{"post":{"tags":["Authentication"],"summary":"Log in","description":"Public endpoint. Returns access + refresh tokens in the Authorization response header.","operationId":"login","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AuthRequestDTO"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string"}}}}},"security":[]}},"/auth/v1/ping":{"get":{"tags":["Authentication"],"summary":"Validate token","description":"Used by the Kong gateway to validate the bearer token and resolve the user id.","operationId":"ping","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string"}}}}}}}},"components":{"schemas":{"UserInfoDTO":{"type":"object","properties":{"userId":{"type":"string"},"password":{"type":"string"},"username":{"type":"string"},"firstName":{"type":"string"},"lastName":{"type":"string"},"phoneNumber":{"type":"integer","format":"int64"},"email":{"type":"string"}}},"