{"openapi":"3.1.0","info":{"title":"ExpenseService API","description":"Expense tracking, filtering and CRUD for ExpenseTracker.","version":"v1"},"servers":[{"url":"/","description":"Via Kong gateway"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"Expenses","description":"Expense CRUD and filtering. The X-User-Id header is injected by the Kong gateway after token validation."}],"paths":{"/expense/v1/updateExpense":{"post":{"tags":["Expenses"],"summary":"Update an existing expense","operationId":"updateExpense","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ExpenseDTO"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string"}}}}}}},"/expense/v1/addExpense":{"post":{"tags":["Expenses"],"summary":"Add a new expense for the current user","operationId":"addExpense","parameters":[{"name":"X-User-Id","in":"header","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ExpenseDTO"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string"}}}}}}},"/expense/v1/getExpense":{"get":{"tags":["Expenses"],"summary":"Get a single expense by id","operationId":"getExpense","parameters":[{"name":"X-User-Id","in":"header","required":true,"schema":{"type":"string"}},{"name":"expenseId","in":"query","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExpenseDTO"}}}}}}},"/expense/v1/getAllExpenses":{"get":{"tags":["Expenses"],"summary":"List all expenses for the current user","operationId":"getAllExpenses","parameters":[{"name":"X-User-Id","in":"header","description":"User id, injected by Kong from the validated token","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/ExpenseDTO"}}}}}}}},"/expense/v1/filterExpenses":{"get":{"tags":["Expenses"],"summary":"Filter expenses by an ISO date-time range (from/to)","operationId":"getFilteredExpenses","parameters":[{"name":"X-User-Id","in":"header","required":true,"schema":{"type":"string"}},{"name":"from","in":"query","required":true,"schema":{"type":"string","format":"date-time"}},{"name":"to","in":"query","required":true,"schema":{"type":"string","format":"date-time"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/ExpenseDTO"}}}}}}}}},"components":{"schemas":{"ExpenseDTO":{"type":"object","properties":{"amount":{"type":"number"},"expenseId":{"type":"string"},"userId":{"type":"string"},"merchant":{"type":"string"},"currency":{"type":"string"},"createdAt":{"type":"string","format":"date-time"}}}},"securitySchemes":{"bearerAuth":{"type":"http","scheme":"bearer","bearerFormat":"JWT"}}}}